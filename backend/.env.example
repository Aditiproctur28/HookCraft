# ── HookCraft backend environment ──────────────────────────
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.

# Google Gemini API key (script generation) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Hugging Face access token (FLUX image generation) — https://huggingface.co/settings/tokens
HF_TOKEN=

# Port the Express server listens on (optional, defaults to 3001)
PORT=3001
