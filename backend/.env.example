# ── HookCraft backend environment ──────────────────────────
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.

# Google Gemini API key (script generation) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Port the Express server listens on (optional, defaults to 3001)
PORT=3001

# ── Image generation (free providers, tried in order) ──────
# Order to try image providers in. Default: Cloudflare first, Pollinations fallback.
# Options: cloudflare, pollinations, huggingface
IMAGE_PROVIDERS=cloudflare,pollinations

# Cloudflare Workers AI (FLUX.1-schnell) — free ~230 images/day, resets daily.
#   Account ID: Cloudflare dashboard → Workers & Pages (right sidebar).
#   API token:  My Profile → API Tokens → Create Token → "Workers AI" template.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Pollinations.ai (free Flux) — works with NO token (rate-limited, may watermark).
#   Optional free token removes the limit + watermark — https://auth.pollinations.ai
POLLINATIONS_TOKEN=

# Hugging Face (FLUX) — OPTIONAL legacy provider. Free tier is metered MONTHLY
# and returns 402 when depleted, so it's not in the default order above.
HF_TOKEN=
